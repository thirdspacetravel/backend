{
  "name": "thirdspacetravel",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "postinstall": "npm run syslink && npm run push && npm run generate",
    "syslink": "ln -s ../storage uploads || true",
    "dev": "NODE_ENV=development tsx watch src/index.ts",
    "prod": "NODE_ENV=production tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "dev:migrate": "dotenv -e .env.development -- prisma migrate dev --name init",
    "dev:push": "dotenv -e .env.development -- prisma db push",
    "dev:generate": "dotenv -e .env.development -- prisma generate",
    "dev:datasource": "dotenv -e .env.development -- prisma init --datasource-provider mysql --output ../src/generated/prisma",
    "dev:studio": "dotenv -e .env.development -- prisma studio",
    "migrate": "dotenv -e .env.production -- prisma migrate dev --name init",
    "push": "dotenv -e .env.production -- prisma db push",
    "generate": "dotenv -e .env.production -- prisma generate",
    "datasource": "dotenv -e .env.production -- prisma init --datasource-provider mysql --output ../src/generated/prisma",
    "studio": "dotenv -e .env.production -- prisma studio"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@prisma/adapter-mariadb": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "@trpc/server": "^11.7.2",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "file-type": "^21.3.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "pg": "^8.16.3",
    "pino": "^10.1.0",
    "pino-http": "^11.0.0",
    "uuid": "^13.0.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/eslint": "^9.6.1",
    "@types/express": "^5.0.5",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.10.1",
    "@types/nodemailer": "^7.0.4",
    "@types/pg": "^8.15.6",
    "@typescript-eslint/eslint-plugin": "^8.47.0",
    "@typescript-eslint/parser": "^8.47.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "pino-pretty": "^13.1.2",
    "prettier": "^3.6.2",
    "prisma": "^7.4.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}