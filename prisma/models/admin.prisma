model AdminUser {
    id                   String    @id @default(uuid())
    firstName            String
    lastName             String
    username             String    @unique
    passwordHash         String
    email                String    @unique
    avatarUrl            String
    newBookingAlerts     Boolean   @default(true)
    paymentConfirmations Boolean   @default(true)
    weeklyDigest         Boolean   @default(false)
    role                 AdminRole @default(TRIP_MANAGER)
    createdAt            DateTime  @default(now())
    updatedAt            DateTime  @updatedAt

    @@map("admin_users")
}
