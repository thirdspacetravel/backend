model Enquiry {
  enquiryNo Int    @id @default(autoincrement())
  id        String @unique @default(uuid())

  // Contact Info
  fullName        String
  institutionName String?
  designation     String?
  email           String
  phoneNumber     String?

  // Enquiry Details
  destination String?
  reply       String?
  groupSize   String?
  travelDates String?
  subject     String
  message     String  @db.Text

  source    String        @default("Website Form")
  status    EnquiryStatus @default(NEW)
  type      EnquiryType   @default(REQUEST)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  user      User?         @relation(fields: [userId], references: [id])
  userId    String?

  @@map("enquiries")
}

enum EnquiryStatus {
  NEW
  PENDING
  ACCEPTED
  REJECTED
}

enum EnquiryType {
  REQUEST
  CONTACT
}
