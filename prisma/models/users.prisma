model User {
    id             String        @id @default(uuid())
    email          String        @unique
    alternateEmail String?
    passwordHash   String
    status         AccountStatus @default(PENDING_VERIFICATION)

    fullName        String
    dateOfBirth     DateTime?
    gender          Gender?
    nationality     String?
    maritalStatus   MaritalStatus?
    anniversaryDate DateTime?
    avatarUrl       String?

    phoneNumber      String?
    altPhoneNumber   String?
    preferredContact ContactMethod @default(EMAIL)
    upiId            String?

    streetAddress String?
    city          String?
    state         String?
    country       String?
    zipCode       String?

    receiveTripUpdates Boolean @default(true)
    receivePromoEmails Boolean @default(false)

    bookings  Booking[]
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    enquiries Enquiry[]

    @@map("users")
}
